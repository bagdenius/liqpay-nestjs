{
	"name": "liqpay-nestjs",
	"description": "LiqPay integration module for NestJS with support for payments, callbacks, and configuration via DI.",
	"version": "0.1.0",
	"type": "module",
	"module": "src/index.ts",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": "./dist/index.js"
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"author": "@bagdenius <bagdenius@gmail.com>",
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"start:dev": "tsc -p tsconfig.build.json --watch",
		"format": "prettier --write \"src/**/*.ts\""
	},
	"devDependencies": {
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/bun": "latest",
		"prettier": "^3.8.1"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@nestjs/common": "^11.1.17",
		"axios": "^1.13.6",
		"crypto": "^1.0.1",
		"zod": "^4.3.6"
	}
}
