{
	"name": "liqpay-nestjs",
	"description": "LiqPay integration module for NestJS with support for payments, callbacks, and configuration via DI.",
	"version": "0.2.14",
	"type": "commonjs",
	"module": "dist/index.js",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"license": "ISC",
	"keywords": [
		"liqpay",
		"nestjs",
		"payments",
		"ukraine",
		"nestjs-module"
	],
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"require": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"author": "@bagdenius <bagdenius@gmail.com>",
	"repository": {
		"type": "git",
		"url": "https://github.com/bagdenius/liqpay-nestjs"
	},
	"homepage": "https://github.com/bagdenius/liqpay-nestjs",
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"format": "prettier --write \"src/**/*.ts\""
	},
	"devDependencies": {
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/node": "^25.4.0",
		"prettier": "^3.8.1",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"@nestjs/common": "^10 || ^11",
		"@nestjs/core": "^10 || ^11"
	},
	"dependencies": {
		"ts-case-convert": "^2.1.0",
		"zod": "^4.3.6"
	},
	"sideEffects": false,
	"engines": {
		"node": ">=18"
	}
}
